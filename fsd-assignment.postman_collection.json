{
    "info": {
        "_postman_id": "d0e12345-6789-abcd-ef01-23456789abcd",
        "name": "FSD Assignment API",
        "description": "Collection for E-commerce Backend API including Auth, Products, Cart, Orders, Payment Mockup, and Image Upload.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Users (Auth)",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
                    }
                },
                {
                    "name": "Login User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.token) {",
                                    "    pm.environment.set(\"jwt_token\", jsonData.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users", "login"] }
                    }
                },
                {
                    "name": "Get All Users",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
                    }
                }
            ]
        },
        {
            "name": "Products",
            "item": [
                {
                    "name": "Get Products",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
                    }
                }
            ]
        },
        {
            "name": "Cart",
            "item": [
                {
                    "name": "Add to Cart",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
                        },
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"userId\": 1,\n    \"productId\": 1,\n    \"quantity\": 2\n}"
                        },
                        "url": { "raw": "{{baseUrl}}/cart", "host": ["{{baseUrl}}"], "path": ["cart"] }
                    }
                }
            ]
        },
        {
            "name": "Payment",
            "item": [
                {
                    "name": "Process Mock Payment",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
                        },
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"amount\": 1500,\n    \"currency\": \"INR\"\n}"
                        },
                        "url": { "raw": "{{baseUrl}}/payment/process", "host": ["{{baseUrl}}"], "path": ["payment", "process"] }
                    }
                },
                {
                    "name": "Verify Mock Payment",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
                        },
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"transactionId\": \"txn_mock_123456\"\n}"
                        },
                        "url": { "raw": "{{baseUrl}}/payment/verify", "host": ["{{baseUrl}}"], "path": ["payment", "verify"] }
                    }
                }
            ]
        },
        {
            "name": "Upload",
            "item": [
                {
                    "name": "Upload Image",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                { "key": "image", "type": "file" }
                            ]
                        },
                        "url": { "raw": "{{baseUrl}}/upload", "host": ["{{baseUrl}}"], "path": ["upload"] }
                    }
                }
            ]
        }
    ],
    "variable": [
        { "key": "baseUrl", "value": "http://localhost:5000" },
        { "key": "jwt_token", "value": "" }
    ]
}
